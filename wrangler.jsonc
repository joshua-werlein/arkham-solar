{
  "name": "arkham-solar",
  "main": "worker/index.js",
  "compatibility_date": "2026-07-15",
  "assets": {
    "directory": "./build",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application",
    "run_worker_first": ["/api/*"]
  },
  "vars": {
    "FROM_EMAIL": "Arkham Solar Website <website@arkhamsolar.com>",
  }
}
